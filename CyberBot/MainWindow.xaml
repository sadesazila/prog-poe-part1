<Window x:Class="CyberBot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cybersecurity Awareness Chatbot"
        Height="700" Width="900"
        MinHeight="600" MinWidth="750"
        WindowStartupLocation="CenterScreen"
        Background="#1a1a2e">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <!-- Header -->
            <RowDefinition Height="Auto"/>
            <!-- Chat display -->
            <RowDefinition Height="*"/>
            <!-- Memory/status bar -->
            <RowDefinition Height="Auto"/>
            <!-- Input area -->
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── HEADER ── -->
        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="CYBER BOT"
                       FontSize="28" FontWeight="Bold"
                       Foreground="#e94560"
                       HorizontalAlignment="Center"
                       FontFamily="Consolas"/>
            <TextBlock Text="Cybersecurity Awareness Assistant"
                       FontSize="13"
                       Foreground="#a8a8b3"
                       HorizontalAlignment="Center"
                       Margin="0,2,0,0"/>
            <Rectangle Height="2" Fill="#e94560" Margin="0,8,0,0"/>
        </StackPanel>

        <!-- ── CHAT DISPLAY ── -->
        <Border Grid.Row="1"
                Background="#16213e"
                CornerRadius="8"
                BorderBrush="#0f3460"
                BorderThickness="1"
                Margin="0,0,0,10">
            <ScrollViewer x:Name="ChatScrollViewer"
                          VerticalScrollBarVisibility="Auto"
                          Padding="10">
                <StackPanel x:Name="ChatPanel"/>
            </ScrollViewer>
        </Border>

        <!-- ── MEMORY STATUS BAR ── -->
        <Border Grid.Row="2"
                Background="#0f3460"
                CornerRadius="5"
                Padding="10,6"
                Margin="0,0,0,10">
            <TextBlock x:Name="MemoryStatusText"
                       Text="Memory: No information stored yet."
                       Foreground="#a8a8b3"
                       FontSize="11"
                       FontFamily="Consolas"/>
        </Border>

        <!-- ── INPUT AREA ── -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBox x:Name="UserInputBox"
                     Grid.Column="0"
                     Height="42"
                     Background="#16213e"
                     Foreground="White"
                     CaretBrush="White"
                     BorderBrush="#0f3460"
                     BorderThickness="1"
                     FontSize="13"
                     FontFamily="Consolas"
                     Padding="10,8"
                     VerticalContentAlignment="Center"
                     KeyDown="UserInputBox_KeyDown"
                     />

            <Button x:Name="SendButton"
                    Grid.Column="1"
                    Content="SEND"
                    Width="80" Height="42"
                    Margin="8,0,0,0"
                    Background="#e94560"
                    Foreground="White"
                    FontWeight="Bold"
                    FontFamily="Consolas"
                    BorderThickness="0"
                    Cursor="Hand"
                    Click="SendButton_Click"/>

            <Button x:Name="ClearButton"
                    Grid.Column="2"
                    Content="CLEAR"
                    Width="80" Height="42"
                    Margin="8,0,0,0"
                    Background="#0f3460"
                    Foreground="White"
                    FontWeight="Bold"
                    FontFamily="Consolas"
                    BorderThickness="0"
                    Cursor="Hand"
                    Click="ClearButton_Click"/>
        </Grid>
    </Grid>
</Window>